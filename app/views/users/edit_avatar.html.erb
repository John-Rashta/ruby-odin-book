 <%= form_with url: avatar_url, method: :put, data: { controller: "form image-preview", action: "turbo:submit-end->form#clear" } do |form| %>
    <img src="<%= current_user.avatar.attached? ? url_for(current_user.avatar) : current_user.avatar_url %>" data-image-preview-target="canvas" class="object-cover size-48 rounded-full">
    <%= form.file_field "user[avatar]", accept: "image/png,image/jpeg,image/jpg,image/webp", data: {
        form_target: "field",
        action: "image-preview#show input->form#disableIfEmptyFields",
        image_preview_target: "source"
    }  %>
    <%= form.submit "Upload", data: {
        form_target: "submit",
    } %>
<% end %>