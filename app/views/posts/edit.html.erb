<%= turbo_frame_tag @post do %>
    <%= form_with model: @post, method: :patch do |form| %>
        <%= form.file_field :image, accept: "image/png,image/jpeg,image/jpg,image/webp"  %>
        <%= form.rich_textarea :content, value: @post.try(:postable).try(:content) %>
        <%= form.submit "Update" %>
    <% end %>
    <%= button_to "Cancel", post_part_path(@post.id), method: "get" %>
<% end %>