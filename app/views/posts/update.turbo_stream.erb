<%= turbo_stream_action_tag :add_class, target: "edit-content-post-#{@post.id}", class: "hidden" %>
<%= turbo_stream_action_tag :remove_class, target: "main-content-post-#{@post.id}", class: "hidden" %>
<%= turbo_stream.update "post-content-#{@post.id}" do %>
    <%= render partial: "application/content", locals: { content: @post } %>
<% end %>