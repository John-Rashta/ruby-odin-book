<div id="post-<%= post.id %>">
    <%= turbo_stream_from "post-#{post.id}" %>
    <%= turbo_frame_tag post do %>
        <% if !local_assigns[:just_created] && current_user && current_user.id == post.creator.id  %>
            <%= button_to "X", post_path(post.id) , method: "delete" %>
            <%= button_to "edit", edit_post_path(post.id), method: "get" %>
        <% end %>
        <div> <%= post.creator.username %> </div>
        <div id="post-content-<%= post.id %>" >
            <% if post.postable_type == "PostImage" %>
                <%= image_tag post.postable.image %>
            <% else %>
                <%= post.postable&.content %>
            <% end %>
        </div>
        <% if current_user %>
            <div id="like-post-<%= post.id %>">
                <%= form_with url:  post_likes_path(post.id), method: "#{!local_assigns[:just_created] && post.liked.any? ? "delete" : "post"}" do |form| %>
                        <%= form.button name: nil, "data-testid": "like-button-post-#{post.id}" do %>
                            <%= icon "thumbs-up", fill: "#{!local_assigns[:just_created] && post.liked.any? ? "black" : "none"}" %>
                        <% end %>
                <% end %>
            </div>
        <% end %>
        <div id="like-post-number-<%= post.id %>"> <%= post.likes_count %> </div>
        <div id="comments-post-number-<%= post.id %>"> <%= post.comments_count %> </div>
    <% end %>
</div>