<%= turbo_stream_from "followships-#{current_user.id}" %>
<div id="followships-<%= current_user.id %>">
    <%= render partial: "users/user", collection: @follows, locals: {custom_start: "follows-user-"} %>
</div>
<% if @pagy.next.present? %>
    <%= turbo_frame_tag :next_page, src: followships_path(page: @pagy.next, format: :turbo_stream), loading: :lazy %>
<% end %>
