<% if @first == "true" %>
    <%= turbo_stream.replace "comments-placeholder-#{@comment.id}" do %>
        <div id="comment-comments-<%= @comment.id %>"> 
            <%= render partial: "comments/comment", collection: @comments %>
        </div>
    <% end %>
    <%= turbo_stream.replace "show-button-#{@comment.id}" do %>
        <button class="hidden" id="show-button-<%= @comment.id %>" data-comments-visibility-target="hideButton" data-action="click->comments-visibility#show">Show Comments</button>
    <% end %>
    <%= turbo_stream.action :remove_class, "comment-visibility-#{@comment.id}", class: "hidden"  %>
<%else %>
    <%= turbo_stream.append "comment-comments-#{@comment.id}" do %>
        <%= render partial: "comments/comment", collection: @comments %>
    <% end %>
<% end %>
<% if @pagy.next.present? %>
    <%= turbo_stream.update "load-more-#{@comment.id}" do %>
        <%= button_to "Load More", comment_comments_part_path(@comment.id, page: @pagy.next, format: :turbo_stream), method: "get" %>
    <% end %>
<% else %>
