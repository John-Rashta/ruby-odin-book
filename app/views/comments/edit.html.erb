<%= turbo_frame_tag @comment do %>
    <%= form_with model: @comment, method: :patch do |form| %>
        <%= form.textarea :content, size: "5x5", value: @comment.content %>
        <%= form.submit "Update" %>
    <% end %>
    <%= button_to "Cancel", comment_part_path(@comment.id), method: "get" %>
<% end %>