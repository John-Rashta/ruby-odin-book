<%= turbo_stream.append "sent-requests", @request %>
<% if @request.table_type == "follow" && @request.sender_id == current_user.id %>
    <%= turbo_stream.update "user-followship-#{@request.user_id}" do %>
        <%= button_to "Cancel Request", request_path(@request.id) , method: "delete" %>
    <% end %>
<% end %>