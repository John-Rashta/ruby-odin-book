<%= turbo_stream.append "requests-#{current_user.id}" do %>
  <%= render @requests%>
<% end %>

<% if @pagy.next.present? %>
  <%= turbo_stream.replace :next_page do %>
    <%= turbo_frame_tag :next_page, src: requests_path(page: @pagy.next, format: :turbo_stream), loading: :lazy %>
  <% end %>
<% end %>