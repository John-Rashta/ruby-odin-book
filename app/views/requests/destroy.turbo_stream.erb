<%= turbo_stream.remove "request-#{@request.id}" %>
<% if @request.table_type == "follow" && @request.sender_id == current_user.id %>
    <%= turbo_stream.update "user-followship-#{@request.user_id}" do %>
        <%= button_to "Follow", requests_path , method: "post", params: {request: { user_id: @request.user.id, table_type: "follow"}}  %>
    <% end %>
<% end %>